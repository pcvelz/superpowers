#!/usr/bin/env bash
# PreToolUse hook: block git commit when native tasks are incomplete
# Only triggers on Bash tool calls containing "git commit".

allow() { echo '{"decision": "allow"}'; exit 0; }

# If anything fails unexpectedly, fall through to allow.
trap 'allow' ERR

INPUT=$(cat)

TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty')
if [[ "$TOOL_NAME" != "Bash" ]]; then allow; fi

COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty')
if ! echo "$COMMAND" | grep -q 'git commit'; then allow; fi

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')
if [[ -z "$TRANSCRIPT_PATH" || ! -f "$TRANSCRIPT_PATH" ]]; then allow; fi

OPEN_TASKS=$(python3 -c "
import json
tasks = {}
next_id = 1
for line in open('$TRANSCRIPT_PATH'):
    try: entry = json.loads(line)
    except: continue
    if entry.get('type') != 'assistant': continue
    for c in entry.get('message', {}).get('content', []):
        if c.get('type') != 'tool_use': continue
        name, inp = c.get('name', ''), c.get('input', {})
        if name == 'TaskCreate':
            tasks[str(next_id)] = 'open'
            next_id += 1
        elif name == 'TaskUpdate':
            tid = str(inp.get('taskId', ''))
            status = inp.get('status', '')
            if tid and status:
                tasks[tid] = status
                try:
                    if int(tid) >= next_id: next_id = int(tid) + 1
                except ValueError: pass
print(sum(1 for s in tasks.values() if s not in ('completed', 'cancelled', 'deleted')))
" 2>/dev/null || echo "0")

if [[ "$OPEN_TASKS" -gt 0 ]]; then
    REASON="$OPEN_TASKS incomplete native task(s). Finish or complete tasks before committing."
    echo "{\"decision\": \"block\", \"reason\": \"$REASON\"}"
    exit 0
fi

echo '{"decision": "allow"}'
exit 0
